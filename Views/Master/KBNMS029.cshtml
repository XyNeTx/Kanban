@model TB_MS_Dock_Code;
@{
    
}
<style>
</style>
<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <div class="row ps-2 pe-2 mb-4">
                    <div class="col-7">
                        <div id="divBtn" class="row">
                            <button type="button" class="btn btn-primary btn-rounded col-2" id="btnInq">Inquiry</button>
                            <button type="button" class="btn btn-success btn-rounded col-2" id="btnNew">New</button>
                            <button type="button" class="btn btn-warning btn-rounded col-2" id="btnUpd">Update</button>
                            <button type="button" class="btn btn-danger btn-rounded col-2" id="btnDel">Delete</button>
                        </div>
                    </div>
                    <div class="col-5">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-dark btn-rounded col-2" id="btnCan">Cancel</button>
                            <a class="btn btn-danger btn-rounded col-2" asp-action="index" asp-controller="home">Exit</a>
                        </div>
                    </div>
                </div>

                <form id="formMain">

                    <div class="input-group">
                        <label class="input-group-text" asp-for="F_Dock_Code"></label>
                        <select class="selectpicker p-0 col-3" asp-for="F_Dock_Code" data-live-search="true" data-size="6">
                            <option value="" hidden></option>
                        </select>
                    </div> 
                    
                    <input type="hidden" asp-for="F_Plant" />

                    <div class="row">

                        <div class="col-6">

                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Start_Date"></label>
                                <input type="text" class="form-control datepicker" asp-for="F_Start_Date" />
                            </div>

                        </div>

                        <div class="col-6">

                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_End_Date"></label>
                                <input type="text" class="form-control datepicker" asp-for="F_End_Date" />
                            </div>

                        </div>

                    </div>

                </form>

                <div class="row">
                    <table id="tableMain" class="table table-bordered border-2 border-dark w-100"></table>
                </div>

                <div class="row mt-2 justify-content-start">
                    <div class="col-6">
                        <button type="button" class="btn btn-success btn-rounded col-3" id="btnSelAll">Select All</button>
                        <button type="button" class="btn btn-primary btn-rounded col-3" id="btnDeselAll">Deselect All</button>
                    </div>
                    
                    <div class="d-flex justify-content-end col-6">
                        <button type="button" class="btn btn-success btn-rounded col-2" id="btnSave">Save</button>
                        <button type="button" class="btn btn-primary btn-rounded col-2" id="btnReport">Report</button>
                    </div>
                </div>


            </div>
        </div>
    </div>

</div>


@using HINOSystem.Models.KB3.Master
@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/Master/KBNMS029.js")"></script>
}
