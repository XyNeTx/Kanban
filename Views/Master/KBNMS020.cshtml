@model VM_KBNMS020;
<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <div class="row ps-2 pe-2 mb-4">
                    <div class="col-7">
                        <div id="divBtn" class="row">
                            <button type="button" class="btn btn-primary btn-rounded col-2" id="btnInq">Inquiry</button>
                            <button type="button" class="btn btn-success btn-rounded col-2" id="btnNew">New</button>
                            <button type="button" class="btn btn-warning btn-rounded col-2" id="btnUpd">Update</button>
                            <button type="button" class="btn btn-danger btn-rounded col-2" id="btnDel">Delete</button>
                        </div>
                    </div>
                    <div class="col-5">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-dark btn-rounded col-2" id="btnCan">Cancel</button>
                            <a class="btn btn-danger btn-rounded col-2" asp-action="index" asp-controller="home">Exit</a>
                        </div>
                    </div>
                </div>

                <form id="formMain">

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Supplier"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_Supplier" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Supplier Code : </label>
                                <input type="text" class="form-control col-6" id="F_Read_Supplier" value="" readonly>
                            </div>
                        </div>
                        
                        <div class="col-3">
                            <div class="input-group">
                                <label class="input-group-text">Cycle : </label>
                                <input type="text" class="form-control col-6" id="F_Read_Cycle" value="" readonly>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4 invisible">
                            <div class="input-group">
                            </div>
                        </div>

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Supplier Name : </label>
                                <input type="text" class="form-control col-9" id="F_Read_SupplierName" value="" readonly>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_KanbanNo"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_KanbanNo" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-3">
                            <div class="input-group">
                                <label class="input-group-text">Kanban No : </label>
                                <input type="text" class="form-control col-8" id="F_Read_Kanban" value="" readonly>
                            </div>
                        </div>
                        
                        <div class="col-3">
                            <div class="input-group">
                                <label class="input-group-text">Box Q'ty : </label>
                                <input type="number" class="form-control col-8" asp-for="F_BoxQty" readonly>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_StoreCD"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_StoreCD" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-3">
                            <div class="input-group">
                                <label class="input-group-text">Store Code : </label>
                                <input type="text" class="form-control col-8" id="F_Read_Store" value="" readonly>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_PartNo"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_PartNo" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Part No. : </label>
                                <input type="text" class="form-control col-8" id="F_Read_PartNo" value="" readonly>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Max_Area"></label>
                                <input type="number" class="form-control col-8" asp-for="F_Max_Area" value="" readonly>
                            </div>
                        </div>

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Part Name : </label>
                                <input type="text" class="form-control col-8" id="F_Read_PartName" value="" readonly>
                            </div>
                        </div>

                    </div>

                </form>

                <div class="row">
                    <table id="tableMain" class="table table-bordered border-2 border-dark w-100"></table>
                </div>

                <div class="row mt-2 justify-content-start">
                    <div class="col-6">
                        <button type="button" class="btn btn-success btn-rounded col-3" id="btnSelAll">Select All</button>
                        <button type="button" class="btn btn-primary btn-rounded col-3" id="btnDeselAll">Deselect All</button>
                    </div>

                    <div class="d-flex justify-content-end col-6">
                        <button type="button" class="btn btn-success btn-rounded col-2" id="btnSave">Save</button>
                        <button type="button" class="btn btn-primary btn-rounded col-2" id="btnReport">Report</button>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>


@using KANBAN.Libs
@using KANBAN.Models.KB3.Master.ViewModel
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/Master/KBNMS020.js")"></script>
}
