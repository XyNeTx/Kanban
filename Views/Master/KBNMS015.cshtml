@model VM_KBNMS015
<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">
                <div class="row">
                    <div class="col-7">
                        <div id="divBtn" class="row">
                            <button type="button" class="btn btn-primary btn-rounded col-2" id="btnInq">Inquiry</button>
                            <button type="button" class="btn btn-success btn-rounded col-2" id="btnNew">New</button>
                            <button type="button" class="btn btn-warning btn-rounded col-2" id="btnUpd">Update</button>
                            <button type="button" class="btn btn-danger btn-rounded col-2" id="btnDel">Delete</button>
                        </div>
                    </div>
                    <div class="col-5">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-dark btn-rounded col-2" id="btnCan">Cancel</button>
                            <a class="btn btn-outline-danger btn-rounded col-2" asp-action="index" asp-controller="home">Exit</a>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <table id="tableMain" class="table table-bordered border-2 border-dark w-100">
                    </table>
                </div>

                <div class="row mt-4">

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Supplier_Code"></label>
                                <select asp-for="F_Supplier_Code" class="selectpicker form-control col-8 p-0" data-live-search="true" data-size="8" data-width="100%" disabled>
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text">Supplier Name</label>
                                <input type="text" id="F_Supplier_Name" class="form-control col-8" readonly />
                            </div>
                        </div>
                        
                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Cycle"></label>
                                <input type="text" id="F_Cycle" class="form-control col-8" readonly />
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Kanban_No"></label>
                                <select asp-for="F_Kanban_No" class="selectpicker form-control col-8 p-0" data-live-search="true" data-size="8" data-width="100%" disabled>
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text">Kanban No.</label>
                                <input type="text" id="F_Kanban_No_Rd" class="form-control col-8" readonly />
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Store_Code"></label>
                                <select asp-for="F_Store_Code" class="selectpicker form-control col-8 p-0" data-live-search="true" data-size="8" data-width="100%" disabled>
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text">Store Code</label>
                                <input type="text" id="F_Store_Code_Rd" class="form-control col-8" readonly />
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Part_No"></label>
                                    <select asp-for="F_Part_No" class="selectpicker form-control col-8 p-0" data-live-search="true" data-size="8" data-width="100%" disabled>
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="input-group">
                                <label class="input-group-text">Part No.</label>
                                <input type="text" id="F_Part_No_Rd" class="form-control col-8" readonly />
                            </div>
                        </div>

                    </div>
                    
                    <div class="row">

                        <div class="col-4 invisible">
                            <div class="input-group">
                                <label class="input-group-text"></label>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="input-group">
                                <label class="input-group-text">Part Name</label>
                                <input type="text" id="F_Part_Name_Rd" class="form-control col-8" readonly />
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Start_Date"></label>
                                <input type="text" class="datepicker form-control col-8" asp-for="F_Start_Date" />
                            </div>
                        </div>

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_End_Date"></label>
                                <input type="text" class="datepicker form-control col-8" asp-for="F_End_Date" />
                            </div>
                        </div>

                    </div> 
                    
                    <div class="row">

                        <div class="col-4">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Color"></label>
                                <input type="color" class="form-control col-8" asp-for="F_Color" />
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="input-group">
                                <label class="input-group-text" asp-for="F_Description"></label>
                                <input type="text" class="form-control col-8" asp-for="F_Description" />
                            </div>
                        </div>

                    </div>

                </div>

                <div class="row mt-4">

                    <div class="col">
                        <div class="row justify-content-start">
                            <button type="button" class="btn btn-success btn-rounded col-3" id="btnSelAll">Select All</button>
                            <button type="button" class="btn btn-primary btn-rounded col-3" id="btnDeselAll">Deselect All</button>
                        </div>
                    </div>

                    <div class="col">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-success btn-rounded col-2" id="btnSave">Save</button>
                            <button type="button" class="btn btn-primary btn-rounded col-2" id="btnRpt">Report</button>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>

</div>



@using KANBAN.Libs
@using KANBAN.Models.KB3.Master.ViewModel
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/Master/KBNMS015.js")"></script>
}