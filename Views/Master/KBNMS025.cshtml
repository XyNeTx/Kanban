<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <div class="row">
                    <div class="col-7">
                        <div id="divBtn" class="row">
                            <button type="button" class="btn btn-primary btn-rounded col-2" id="btnInq">Inquiry</button>
                            <button type="button" class="btn btn-success btn-rounded col-2" id="btnNew">New</button>
                            <button type="button" class="btn btn-warning btn-rounded col-2" id="btnUpd">Update</button>
                            <button type="button" class="btn btn-danger btn-rounded col-2" id="btnDel">Delete</button>
                        </div>
                    </div>
                    <div class="col-5">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-dark btn-rounded col-2" id="btnCan">Cancel</button>
                            <a class="btn btn-outline-danger btn-rounded col-2" asp-action="index" asp-controller="home">Exit</a>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <table id="tableMain" class="table table-bordered border-2 border-dark w-100">
                    </table>
                </div>

                <div class="row mt-4">
                    <div class="row">

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Logistical Supplier</label>
                                <select id="inpSupplierCode" class="selectpicker form-control col-7 p-0" data-live-search="true" data-size="8" data-width="100%" disabled>
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Truck Type</label>
                                <select id="inpTruckType" class="selectpicker form-control col-7 p-0" data-live-search="true" data-size="8" data-width="100%" disabled>
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Weight</label>
                                <input type="number" id="inpWeight" value="0" min="0" class="form-control col-7" disabled />
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Width (mm)</label>
                                <input type="number" id="inpWidth" value="0" min="0" class="form-control col-7" disabled />
                            </div>
                        </div>

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Height (mm)</label>
                                <input type="number" id="inpHeight" value="0" min="0" class="form-control col-7" disabled />
                            </div>
                        </div>

                    </div>
                    
                    <div class="row">

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Long (mm)</label>
                                <input type="number" id="inpLong" value="0" min="0" class="form-control col-7" disabled />
                            </div>
                        </div>

                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">M3</label>
                                <input type="number" id="inpM3" value="0" min="0" class="form-control col-7" disabled />
                            </div>
                        </div>

                    </div>
                     
                    <div class="row">

                        <div class="col-5">
                            <div class="input-group">
                                <span class="input-group-text">Start Date</span>
                                <input type="text" id="inpStartDate" class="datepicker col-10" disabled />
                            </div>
                        </div>

                        <div class="col-5">
                            <div class="input-group">
                                <span class="input-group-text">End Date</span>
                                <input type="text" id="inpEndDate" class="datepicker col-10" disabled />
                            </div>
                        </div>

                    </div>

                </div>

                <div class="row mt-4">

                    <div class="col">
                        <div class="row justify-content-start">
                            <button type="button" class="btn btn-success btn-rounded col-3" id="btnSelAll">Select All</button>
                            <button type="button" class="btn btn-primary btn-rounded col-3" id="btnDeselAll">Deselect All</button>
                        </div>
                    </div>

                    <div class="col">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-success btn-rounded col-2" id="btnSave">Save</button>
                            <button type="button" class="btn btn-primary btn-rounded col-2" id="btnRpt">Report</button>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>

</div>



@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/Master/KBNMS025.js")"></script>
}