@model TB_MS_PairOrder;

<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <div class="row ps-2 pe-2 mb-4">
                    <div class="col-7">
                        <div id="divBtn" class="row">
                            <button type="button" class="btn btn-primary btn-rounded col-2" id="btnInq">Inquiry</button>
                            <button type="button" class="btn btn-success btn-rounded col-2" id="btnNew">New</button>
                            <button type="button" class="btn btn-warning btn-rounded col-2" id="btnUpd">Update</button>
                            <button type="button" class="btn btn-danger btn-rounded col-2" id="btnDel">Delete</button>
                        </div>
                    </div>
                    <div class="col-5">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-dark btn-rounded col-2" id="btnCan">Cancel</button>
                            <a class="btn btn-danger btn-rounded col-2" asp-action="index" asp-controller="home">Exit</a>
                        </div>
                    </div>
                </div>

                <div class="row mt-2 mb-4">
                    <table id="tableMain" class="table table-bordered border-2 border-dark w-100"></table>
                </div>

                <form id="formMain">

                    <div class="row">

                        <div class="col-4">

                            <div class="input-group">
                                <label class="input-group-text col-4" asp-for="F_Supplier_Cd"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_Supplier_Cd" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>

                        </div> 
                        
                        <div class="col-5">

                            <div class="input-group">
                                <label class="input-group-text col-3" for="F_Supplier_Name">Supplier Name</label>
                                <input type="text" value="" class="form-control col-8" id="F_Supplier_Name" readonly />
                            </div>

                        </div> 
                        
                        <div class="col-3">

                            <div class="input-group">
                                <label class="input-group-text col-3" for="F_Cycle">Cycle</label>
                                <input type="text" value="" class="form-control col-8" id="F_Cycle" readonly />
                            </div>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">

                            <div class="input-group">
                                <label class="input-group-text col-4" asp-for="F_Kanban_No"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_Kanban_No" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>

                        </div>

                        <div class="col-5">

                            <div class="input-group">
                                <label class="input-group-text col-3" for="F_Kanban_No_Rd">Kanban No</label>
                                <input type="text" value="" class="form-control col-8" id="F_Kanban_No_Rd" readonly />
                            </div>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">

                            <div class="input-group">
                                <label class="input-group-text col-4" asp-for="F_Store_Cd"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_Store_Cd" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>

                        </div>

                        <div class="col-5">

                            <div class="input-group">
                                <label class="input-group-text col-3" for="F_Store_Cd_Rd">Store Code</label>
                                <input type="text" value="" class="form-control col-8" id="F_Store_Cd_Rd" readonly />

                            </div>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">

                            <div class="input-group">
                                <label class="input-group-text col-4" asp-for="F_Part_No"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_Part_No" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>

                        </div>

                        <div class="col-5">

                            <div class="input-group">
                                <label class="input-group-text col-3" for="F_Part_No_Rd">Part No</label>
                                <input type="text" value="" class="form-control col-8" id="F_Part_No_Rd" readonly/>

                            </div>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4 invisible">

                            <div class="input-group">
                            </div>

                        </div>

                        <div class="col-5">

                            <div class="input-group">
                                <label class="input-group-text col-3" for="F_PartName">Part Name</label>
                                <input type="text" value="" class="form-control col-8" id="F_PartName" readonly/>
                            </div>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">

                            <div class="input-group">
                                <label class="input-group-text col-4" asp-for="F_Group"></label>
                                <select class="selectpicker p-0 col-8" asp-for="F_Group" data-live-search="true" data-size="6">
                                    <option value="" hidden></option>
                                </select>
                            </div>

                        </div>

                        <div class="col-5">

                            <div class="input-group">
                                <label class="input-group-text col-3" asp-for="F_Qty"></label>
                                <input type="number" value="0" min="0" class="form-control col-8" asp-for="F_Qty" />
                            </div>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-4">

                            <div class="input-group">
                                <label class="input-group-text col-4" asp-for="F_Start_Date"></label>
                                <input type="text" class="datepicker form-control col-8" asp-for="F_Start_Date"/>
                            </div>

                        </div>

                        <div class="col-5">

                            <div class="input-group">
                                <label class="input-group-text col-3" asp-for="F_End_Date"></label>
                                <input type="text" class="datepicker form-control col-8" asp-for="F_End_Date" />
                            </div>

                        </div>

                    </div>

                </form>

                <div class="row mt-2 justify-content-start">

                    <div class="d-flex justify-content-end col-12">
                        <button type="button" class="btn btn-success btn-rounded col-1" id="btnSave">Save</button>
                        <button type="button" class="btn btn-primary btn-rounded col-1" id="btnReport">Report</button>
                    </div>

                </div>

            </div>
        </div>
    </div>

</div>


@using HINOSystem.Models.KB3.Master
@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/Master/KBNMS016.js")"></script>
}