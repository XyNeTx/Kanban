                                            <i class="fas fa-bug" title="System History"></i>
                                        </a>
                                    </h4>
                                </li>
                            </ul>
                            <ul class="nav-right">
                                <li style="font-size:0.7rem;font-weight:bold;line-height:1.5;padding-top:3px;color:blue;padding: 0 0px;">
