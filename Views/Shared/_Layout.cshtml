                        </nav>
                        <div class="pcoded-content">
                            <div class="pcoded-inner-content">

                                
                                @if (ViewData["ComponentToolbar"].ToString() == "true")
                                {
                                    <div class="btn-toolbar" role="toolbar" aria-label="Toolbar">
                                        <div class="btn-group btn-group-sm me-2" role="group" aria-label="Toolbar">
                                            
                                            <button type="button" class="btn btn-success"
                                                    id="ButtonLayoutSearch"
                                                    title="@(ViewData["ComponentToolbarSearchText"].ToString() != "" ? ViewData["ComponentToolbarSearchText"].ToString() : "Search")"
                                            @(ViewData["ComponentToolbarSearch"].ToString() == "true" ? "" : "disabled")>
                                                <i class="ti-search"></i>
                                            </button>
                                            <button type="button" class="btn btn-success"
                                                    id="ButtonLayoutSave"
                                                    onclick="onSave()"
                                                    title="@(ViewData["ComponentToolbarSaveText"].ToString() != "" ? ViewData["ComponentToolbarSaveText"].ToString() : "Save")"
                                            @(ViewData["ComponentToolbarSave"].ToString() == "true" ? "" : "disabled")>
                                                <i class="ti-save"></i>
                                            </button>
                                            @*<div class="btn-group" role="group">*@
                                            <button type="button" id="ButtonLayoutGroupExport" class="btn btn-success dropdown-toggle" 
                                                    data-bs-toggle="dropdown" aria-expanded="false"
                                                    title="@(ViewData["ComponentToolbarExportText"].ToString() != "" ? ViewData["ComponentToolbarExportText"].ToString() : "Export drop down menu")"
                                            @(ViewData["ComponentToolbarExport"].ToString() == "true" ? "" : "disabled")>
                                                <i class="fas fa-download"></i>
                                            </button>
                                            <ul class="dropdown-menu" aria-labelledby="btnGroupExport">
                                                <li><a class="dropdown-item" id="ButtonLayoutExport_Copy" href="#"><i class="ti-clipboard"></i>Clipboard</a></li>
                                                <li><a class="dropdown-item" id="ButtonLayoutExport_CSV" href="#"><i class="fas fa-file-download"></i>CSV</a></li>
                                                <li><a class="dropdown-item" id="ButtonLayoutExport_XLS" href="#"><i class="far fa-file-excel"></i>Excel</a></li>
                                                <li><a class="dropdown-item" id="ButtonLayoutExport_PDF" href="#"><i class="far fa-file-pdf"></i>PDF</a></li>
                                            </ul>
                                            @*</div>*@

                                            <button type="button" class="btn btn-success"
                                                    id="ButtonLayoutExport_Print"
                                                    title="@(ViewData["ComponentToolbarPrintText"].ToString() != "" ? ViewData["ComponentToolbarPrintText"].ToString() : "Print")"
                                            @(ViewData["ComponentToolbarPrint"].ToString() == "true" ? "" : "disabled")>
                                                <i class="ti-printer"></i>
                                            </button>
                                            <button type="button" class="btn btn-success" 
                                                    id="ButtonLayoutExecute"
                                                    onclick="onExecute()"
                                                    title="@(ViewData["ComponentToolbarExecuteText"].ToString() != "" ? ViewData["ComponentToolbarExecuteText"].ToString() : "Run/Execute")"
                                            @(ViewData["ComponentToolbarExecute"].ToString() == "true" ? "" : "disabled")>
                                                <i class="fas fa-bolt"></i>
                                            </button>
                                            <button type="button" class="btn btn-success" 
                                                    id="ButtonLayoutDelete"
                                                    onclick="onDeleteAll()"
                                                    title="@(ViewData["ComponentToolbarDeleteText"].ToString() != "" ? ViewData["ComponentToolbarDeleteText"].ToString() : "Delete")"
                                            @(ViewData["ComponentToolbarDelete"].ToString() == "true" ? "" : "disabled")>
                                                <i class="far fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </div>

                                }
                                
                                @RenderBody()

                                <div id="styleSelector"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div id="load-wrapper" class="d-flex justify-content-center">
