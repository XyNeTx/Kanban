                                            data-dropdown-in="fadeIn"
                                            data-dropdown-out="fadeOut">
                                            <li>
                                                <a href="#" data-bs-toggle="modal" data-bs-target="#ModalUserProfile" id="_Layout_profile">
                                                    <i class="feather icon-user"></i>Profile
                                                </a>
                                            </li>
                                            <li>
                                                <div onclick="$('#styleSelector').attr('class','open')">
                                                    <a href="#!" id="_Layout_setting">
                                                        <i class="feather icon-settings"></i>Settings
                                                    </a>
                                                </div>
                                            </li>
