@using KANBAN.Libs
<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <div class="row">

                    <div class="col-10">
                    
                        <div class="row">
                            <div class="input-group col-6">
                                <span class="input-group-text">Order No</span>
                                <select class="selectpicker form-control col-6" id="inpOrderNo">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col">
                                <input type="checkbox" class="form-check-input border-1 border-dark ms-1" id="chkSearch" />
                                <label class="form-check-label ms-4 justify-content-start align-items-center" for="chkSearch">Search by Delivery Date</label>
                            </div>
                        </div>

                        <fieldset class="mt-3 border-4 border-dark">
                    
                            <legend>Delivery Date</legend>

                            <div class="row">

                                <div class="col">
                                    <div class="input-group">
                                        <span class="input-group-text">Delivery Date From</span>
                                        <input type="text" class="datepicker form-control col-12" id="inpDeliveryDateFrom" readonly />
                                    </div>
                                </div>

                                <div class="col">
                                    <div class="input-group">
                                        <span class="input-group-text">Delivery Date To</span>
                                        <input type="text" class="datepicker form-control col-12" id="inpDeliveryDateTo" readonly/>
                                    </div>
                                </div>

                            </div>

                        </fieldset>
                    
                    </div>

                    <div class="col-2">

                        <div class="d-flex flex-column justify-content-end" style="height: 28vh;">
                            <div class="row justify-content-center">
                                <div class="col-8">
                                    <button type="button" class="btn btn-warning w-100" id="btnUpd">Update Cycle</button>
                                </div>
                            </div>
                            <div class="row justify-content-center mt-2">
                                <div class="col-8">
                                    <button type="button" class="btn btn-success w-100" id="btnSearch">Search</button>
                                </div>
                            </div>
                        </div>


                    </div>

                </div>

                <div class="row mt-4">

                    <div class="col-10">

                        <table id="tableMain" class="table table-bordered border-2 border-dark w-100"></table>

                    </div>

                    <div class="col-2">

                        <div class="row justify-content-center mt-4 pt-4">
                            <button type="button" class="btn btn-outline-success btn-rounded col-8 mt-2" id="btnSel">Select All</button>
                            <button type="button" class="btn btn-outline-warning btn-rounded col-8 mt-2" id="btnDesel">Deselect All</button>
                        </div>

                    </div>

                </div>

                <div class="row justify-content-end mt-2">

                    <button type="button" class="btn btn-primary btn-rounded col-1" id="btnConf">Confirm</button>
                    <a class="btn btn-danger col-1" asp-controller="home" asp-action="index">Exit</a>

                </div>

            </div>
        </div>
    </div>

</div>


@section Scripts{
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/ServiceData/KBNIM001C.js")"></script>
}
