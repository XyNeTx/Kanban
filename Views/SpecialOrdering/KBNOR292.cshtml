
<div class="row">
    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">
                <div class="row mt-2">
                    <h4>Search Data</h4>
                </div>
                <div class="row mt-2">
                    <div class="row justify-content-center">
                        <div class="col-8">
                            <div class="row">
                                <div class="input-group">
                                    <label for="mthSurveyIssued" class="input-group-text">Survey Issued In Month</label>
                                    <input type="month" class="form-control col-4" id="mthSurveyIssued" value="@DateTime.Now.ToString("yyyy-MM")" />
                                </div>
                            </div>
                            <div class="row">
                                <div class="input-group">
                                    <label for="selSuppCD" class="input-group-text">Supplier Code</label>
                                    <select class="selectpicker col-4 p-0" id="selSuppCD">
                                        <option value="" hidden>-- Select Supplier Code --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row">
                                <span class="form-control col-8 fw-bold ms-2 fs-6" id="spanSuppName">
                                    
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-4 justify-content-end">
                        <button type="button" class="btn btn-rounded btn-success col-2" id="btnReport">Report</button>
                        <a asp-controller="OrderingProcess" asp-action="KBNOR200" class="btn btn-danger btn-rounded col-2 ms-1">Exit</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @using KANBAN.Libs
    @section Scripts {
        <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/SpecialOrdering/KBNOR292.js")"></script>
    }
