
<div class="row">
    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">
                <div class="row">
                    <table class="table table-bordered w-100" id="tableMain">

                    </table>
                </div>
                <div class="row mt-3">
                    <div class="col">
                        <div class="row justify-content-start">
                            <button type="button" class="btn btn-outline-dark col-3 me-2" id="chkAll">Check All</button>
                            <button type="button" class="btn btn-outline-dark col-3" id="unChkAll">Uncheck All</button>
                        </div>
                    </div>
                    <div class="col">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-primary col-2" id="btnUpload">Upload</button>
                            <a asp-controller="OrderingProcess" asp-action="KBNOR200" class="btn btn-danger col-2">Exit</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/SpecialOrdering/KBNOR230.js")"></script>
}