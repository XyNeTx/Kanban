<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">


                <div class="row mt-3 ps-2 pe-2" id="divButton">
                    <div class="col">
                        <div class="row justify-content-start">
                            <button type="button" class="btn btn-primary col-2" id="btnInq">Inquiry</button>
                            <button type="button" class="btn btn-dark col-2" id="btnNew">New</button>
                            <button type="button" class="btn btn-warning col-2" id="btnUpd">Update</button>
                            <button type="button" class="btn btn-danger col-2" id="btnDel">Delete</button>
                        </div>
                    </div>
                    <div class="col">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-warning col-2" id="btnCan">Cancel</button>
                            <a asp-controller="OrderingProcess" asp-action="KBNOR200" class="btn btn-danger col-2">Exit</a>
                        </div>
                    </div>
                </div>



                <div class="row mt-3">
                    <table class="table table-bordered w-100" id="tableMain">

                    </table>
                </div>

                <form id="frmCondition">
                
                    <div class="row mt-3">
                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Supplier Code : </label>
                                    <select class="selectpicker col-8 p-0" id="inpSupplier" data-live-search="true" data-width="100%" disabled>
                                        <option value="" hidden>-- Select Supplier --</option>
                                    </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control" id="inpSupplierName" placeholder="Supplier Name" readonly>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-11">
                            <div class="input-group">
                                <label class="input-group-text">Attention : </label>
                                <input type="text" class="form-control" id="inpAttention" readonly>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-7">
                            <div class="input-group">
                                <label class="input-group-text">Telephone : </label>
                                <input type="text" class="form-control" id="inpTelephone" readonly>
                            </div>
                        </div>
                        <div class="col-5">
                            <div class="input-group">
                                <label class="input-group-text">Fax : </label>
                                <input type="text" class="form-control" id="inpFax" readonly>
                            </div>
                        </div>
                    </div>

                </form>

                <div class="row ps-2 pe-2 mt-3">

                    <div class="col">
                        <div class="row justify-content-start">
                            <button type="button" class="btn btn-outline-dark col-2" id="btnSel">Select All</button>
                            <button type="button" class="btn btn-outline-danger col-3" id="btnDesel">Deselect All</button>
                        </div>
                    </div>

                    <div class="col">
                        <div class="row justify-content-end">
                            <button type="button" class="btn btn-success col-2" id="btnSave">Save</button>
                            <button type="button" class="btn btn-primary col-2" id="btnReport">Report</button>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>

</div>



@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/SpecialOrdering/KBNOR296.js")"></script>
}