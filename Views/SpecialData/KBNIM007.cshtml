
<div class="row">
    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">
                <div class="row">
                    <div class="row justify-content-start" id="divBtn">
                        <button type="button" id="btnInq" class="btn btn-success col">Inquiry</button>
                        <button type="button" id="btnNew" class="btn btn-primary col">New</button>
                        <button type="button" id="btnUpd" class="btn btn-warning col">Update</button>
                        <button type="button" id="btnDel" class="btn btn-danger col">Delete</button>
                        <button type="button" id="btnCan" class="btn btn-warning col" disabled>Cancel</button>
                        <button type="button" id="btnRptPar" class="btn btn-success col">Report Parent</button>
                        <button type="button" id="btnRpt" class="btn btn-primary col">Report</button>
                    </div>
                    <div class="col-6">
                        <div class="row ms-1 me-4 mt-2">
                            <div class="col">
                                
                            </div>
                        </div>
                        <div class="row mt-4" id="divInput">
                            <div class="row">
                                <div class="input-group">
                                    <label class="input-group-text" for="mthDeliYM">Delivery YM</label>
                                    <input type="month" class="form-control col-4" value="@DateTime.Now.ToString("yyyy-MM")" id="mthDeliYM" disabled />
                                </div>
                            </div>
                            <div class="row">
                                <div class="input-group">
                                    <label class="input-group-text" for="selCustomerOrder">Customer Order No.</label>
                                    <select class="selectpicker col-5 ps-0" id="selCustomerOrder" data-live-search="true" data-size="7" disabled>
                                    </select>
                                </div>
                            </div>
                            <div class="row">
                                <div class="input-group">
                                    <label class="input-group-text" for="selStoreCode">Store Code</label>
                                    <select class="selectpicker col-5 ps-0" id="selStoreCode" data-live-search="true" data-size="7" disabled></select>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col">
                                    <div class="input-group">
                                        <label class="input-group-text" for="selPartNo">Part No.</label>
                                        <select class="selectpicker col-5 ps-0" id="selPartNo" data-live-search="true" data-size="7" disabled></select>
                                        <span class="col pt-2 ps-1 pb-2 pe-1" id="spanPartName"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="input-group">
                                    <label class="input-group-text" for="inpDate">Issued Date</label>
                                    <input type="text" class="form-control" id="inpDate" readonly />
                                </div>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <table class="table w-100 table-bordered ms-1 mt-2" id="tableMain">
                                <thead>
                                    <tr>
                                        <th class="bg-danger text-center">SUN</th>
                                        <th class="bg-warning text-center">MON</th>
                                        <th style="background-color:lightpink;text-align:center">TUE</th>
                                        <th class="bg-success text-center">WED</th>
                                        <th style="background-color:orange;text-align:center">THU</th>
                                        <th style="background-color:lightskyblue;text-align:center">FRI</th>
                                        <th style="background-color:mediumpurple;text-align:center">SAT</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                        <div class="row mt-2">
                            <div class="row justify-content-center">
                                <button type="button" class="btn btn-success col-2" id="btnSave" disabled>Save</button>
                                <a class="btn btn-danger col-2" asp-controller="OrderingProcess" asp-action="KBNOR200">Exit</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <table class="table w-100 table-bordered" id="tableSub">
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/SpecialData/KBNIM007.js")"></script>
}
