<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <form id="frmCondition">

                    <fieldset class="fieldset">
                        <legend>Detail Data : </legend>

                        <div class="row">
                            <div class="col-6">
                                <item type="table" id="tblPDS"></item>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col">
                                <item type="table" id="tblSeparate"></item>
                            </div>
                        </div>

                    </fieldset>

                    <div class="row mt-2">
                        <div class="col">
                            <fieldset class="fieldset" id="fldDeliveryDate" disabled>
                                <legend><item type="check" id="chkDeliveryDate" label="Change Delivery Date :"></item></legend>

                                <div class="row">
                                    <div class="col-3">
                                        <item type="date" id="F_DeliveryFrom" label="From" format="yyyy-mm-dd" default="now"></item>
                                    </div>
                                </div>
                            </fieldset>

                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>

</div>




@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/UrgentOrder/KBNIM013EXP.js")"></script>
}