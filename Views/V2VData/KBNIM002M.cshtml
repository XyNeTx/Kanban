<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <form id="frmCondition">
                </form>

                <div class="row">
                    <div class="col mt-2">
                        <item type="table" id="tblMaster" label="Select Data"></item>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>


<!-- Modal Master -->
<div class="modal fade" id="modalMaster" tabindex="-1" aria-labelledby="modalMasterLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalMasterLabel"> @ViewData["AppName"] <span></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="frmMaster" class="needs-validation" autocomplete="off" novalidate>
                <input type="hidden" class="form-control" id="_Action" name="_Action" value="POST">
                <input type="hidden" class="form-control" id="_ID" name="_ID">
                <input type="hidden" class="form-control" id="F_Plant" name="F_Plant">

                <div class="modal-body" style="padding-left:10px;padding-top:5px;padding-right:10px;">

                    <div class="btn-toolbar" role="toolbar" aria-label="Toolbar">
                        <div class="btn-group btn-group-sm me-2" role="group" aria-label="Toolbar">

                            <button type="button" class="btn btn-success" id="btnSave" name="btnSave" onclick="onSave();" title="Save data" @(ViewData["ComponentToolbarSave"].ToString() == "true" ? "" : "disabled")>
                                <i class="ti-save"></i>
                            </button>
                            <button type="button" class="btn btn-success" id="btnPrint" name="btnPrint" onclick="onPrint();" title="Print" @(ViewData["ComponentToolbarPrint"].ToString() == "true" ? "" : "disabled")>
                                <i class="ti-printer"></i>
                            </button>
                            <button type="button" class="btn btn-success" id="btnExecute" name="btnExecute" onclick="onExecute()" title="Execute/Run" @(ViewData["ComponentToolbarExecute"].ToString() == "true" ? "" : "disabled")>
                                <i class="fas fa-bolt"></i>
                            </button>
                            <button type="button" class="btn btn-success" id="btnDelete" name="btnDelete" onclick="onDelete();" title="Delete" @(ViewData["ComponentToolbarDelete"].ToString() == "true" ? "" : "disabled")>
                                <i class="far fa-trash-alt"></i>
                            </button>

                        </div>
                    </div>

                    <fieldset class="fieldset">
                        <legend>Detail Data : <i style="color:orange">Remark : Order No. ไม่เลือกออกหมด</i></legend>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <item type="text" id="F_OrderNo" label="Order No."></item>
                            </div>
                            <div class="col-md-6">
                                <item type="date" id="F_Issue_Date" label="Order Issue Date" format="yyyy-mm-dd" default="now" noedit required></item>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <div class="row g-2">
                                    <div class="col">
                                        <item type="text" id="F_PartNo" label="Part No."></item>
                                    </div>
                                </div>
                                <div class="row g-2">
                                    <div class="col">
                                        <item type="text" id="F_StoreCode" label="Store Code"></item>
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <fieldset class="fieldset">
                                    <legend>Type For Import : </legend>
                                    <div class="row">
                                        <div class="col">
                                            <item type="radio" id="TypeForImport" value="Pakistan" label="Pakistan" checked></item>
                                        </div>
                                        <div class="col">
                                            <item type="radio" id="TypeForImport" value="Egypt" label="Egypt"></item>
                                        </div>
                                        <div class="col">
                                            <item type="radio" id="TypeForImport" value="Others" label="Others"></item>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <item type="date" id="F_Delivery_Date" label="Adv. Delivery Date" format="yyyy-mm-dd" default="now" noedit required></item>
                            </div>
                            <div class="col-md-6">
                                <item type="currency" id="F_Qty" label="Qty."></item>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md">
                                <item type="textarea" id="F_Remark" label="Remark"></item>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md">
                                <i style="color:red">Remark : This function can not insert new data.</i>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md">
                                <i style="color:orange">Remark : New ==>Old Order No.,New Part No. And New Order No.</i>
                            </div>
                        </div>
                        
                    </fieldset>


                </div>
            </form>

            <div class="modal-footer" style="padding-left:20px; padding-right:20px;">
                <i class="modal-reference mr-auto">Reference Code : <i id="_REFERCODE_"></i></i>
                @if (ViewData["UserGroupID"].ToString() == "1" || ViewData["UserGroupID"].ToString() == "2")
                {
                    <a href="#" data-bs-toggle="modal" data-bs-target="#ModalHistory" data-bs-remote="UserMaintenance">
                        <i class="fas fa-scroll" title="History Log"></i>
                    </a>
                }
            </div>
        </div>
    </div>
</div>




@section Scripts{
    <script type="text/javascript" src="~/assets/js/History/UserMaintenance.js"></script>
    <script type="text/javascript" src="~/assets/.script/Template/Master.js"></script>
    <script type="text/javascript" src="~/assets/.script/V2VData/KBNIM002M.js?@ViewData["Version"]"></script>
}
