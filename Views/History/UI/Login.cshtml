@section Scripts{

    <script type="text/javascript">


        $(document).ready(function () {
            var _i18n = i18n.Language;
            xi18n.initial(i18n['@ViewData["Action"].ToString()']);

            //console.log(i18n.System);

            var tblData, tblDetail, tblDescription;
            onInitial = function () {
                xSplash.show();
                xSplash.text('Loading data');

                //### Data
                tblData = xDataTable.Initial({
                    name: 'tblData',
                    running: 0,
                    order :[[1, 'desc']],
                    columnTitle: {
                        "EN": ['No.', 'Action At', 'User Code', 'Name', 'Surname', 'ชื่อ', 'นามสกุล'],
                        "TH": ['No.', 'วันที่', 'ชื่อผู้ใช้', 'ชื่อ (English)', 'นามสกุล (English)', 'ชื่อ', 'นามสกุล'],
                    },
                    column:
                        [
                            { "data": "RunningNo" },
                            { "data": "ActionAt" },
                            { "data": "Code" },
                            { "data": "Name" },
                            { "data": "Surname" },
                            { "data": "NameTH" },
                            { "data": "SurnameTH" }
                        ],
                    columnDefs:
                        [
                            { targets: 1, className: 'maskdate' }
                        ],
                    addnew: false,
                    rowclick: function (row) {
                        onClickData(row);
                    },
                    then: function (config) {
                        xSplash.hide();
                    }
                });


                //### Detail
                tblDetail = xDataTable.Initial({
                    name: 'tblDetail',
                    running: 0,
                    order: [[1, 'desc']],
                    columnTitle: {
                        "EN": ['No.', 'Start At', 'Finish At', 'Process Time (min)'],
                        "TH": ['No.', 'เริ่มเมื่อ', 'สิ้นสุดเมื่อ', 'เวลาที่อยู่ในระบบ'],
                    },
                    column:
                        [
                            { "data": "RunningNo" },
                            { "data": "StartAt" },
                            { "data": "FinishAt" },
                            { "data": "ProcessTime" }
                        ],
                    columnDefs:
                        [
                            { targets: 3, className: 'masknumber' }
                        ],
                    addnew: false,
                    rowclick: function (row) {
                        onClickDetail(row);
                    },
                    then: function (config) {
                        xSplash.hide();
                    }
                });


                //### Description
                tblDescription = xDataTable.Initial({
                    name: 'tblDescription',
                    running: 0,
                    //order: [[1, 'desc']],
                    columnTitle: {
                        "EN": ['No.', 'ActionAt', 'ActionType', 'ControllerName', 'ActionName', 'Result'],
                        "TH": ['No.', 'ActionAt', 'ActionType', 'ControllerName', 'ActionName', 'Result'],
                    },
                    column:
                        [
                            { "data": "RunningNo" },
                            { "data": "ActionAt" },
                            { "data": "ActionType" },
                            { "data": "ControllerName" },
                            { "data": "ActionName" },
                            { "data": "Result" }
                        ],
                    //columnDefs:
                    //    [
                    //        { targets: 3, className: 'masknumber' }
                    //    ],
                    addnew: false,
                    rowclick: function (row) {
                        onClickDescription(row);
                    },
                    then: function (config) {
                        xSplash.hide();
                    }
                });


            }
            onInitial();



            onLoad = function () {
                xSplash.show();
                xSplash.text('Loading data');

                $.ajax({
                    type: "POST",
                    headers: ajexHeader,
                    contentType: "application/json; charset=utf-8",
                    url: '@Url.Action("getData","HistoryLogin")',
                    data: ajaxPostData({
                        'System': i18n.System
                    }),
                    success: function (response) {
                        //console.log(response);

                        if (response.response == 'OK') {

                            $('#tblData').dataTable().fnClearTable();
                            if (response.data.length > 0) {
                                $('#tblData').dataTable().fnAddData(response.data);
                            }
                            xSplash.hide();

                        } else {
                            if (response.message != '') xSwal.error("Error", response.message);
                            xSplash.hide();

                        }

                    },
                    error: function (xhr, status, error) {
                        console.error(error);
                    }
                });

            }
            onLoad();




            onClickData = function (row = null) {
                $('#frmModalData').removeClass('was-validated');
                $('#frmModalDataLabel span').text(' [' + row.Code + ']');
                $('#frmModalData #Code').attr('readonly', 'true');

                $.each(row, function (key, value) {
                    $('#frmModalData #' + key).val(value);
                });

                $.ajax({
                    type: "POST",
                    headers: ajexHeader,
                    contentType: "application/json; charset=utf-8",
                    url: '@Url.Action("getDetail","HistoryLogin")',
                    data: ajaxPostData({
                        'System': i18n.System,
                        'UserCode': row.Code,
                        'Date': row.ActionAt
                    }),
                    success: function (response) {
                        //console.log(response);

                        if (response.response == 'OK') {

                            $('#tblDetail').dataTable().fnClearTable();
                            if (response.data.length > 0) {
                                $('#tblDetail').dataTable().fnAddData(response.data);
                            }
                            xSplash.hide();

                        } else {
                            if (response.message != '') xSwal.error("Error", response.message);
                            xSplash.hide();

                        }

                        $('#ModalData').modal('toggle');
                    }
                });
            }




            onClickDetail = function (row = null) {
                $.ajax({
                    type: "POST",
                    headers: ajexHeader,
                    contentType: "application/json; charset=utf-8",
                    url: '@Url.Action("getDescription","HistoryLogin")',
                    data: ajaxPostData({
                        'Session': row.Token
                    }),
                    success: function (response) {

                        if (response.response == 'OK') {

                            $('#tblDescription').dataTable().fnClearTable();
                            if (response.data.length > 0) {
                                $('#tblDescription').dataTable().fnAddData(response.data);
                            }
                            xSplash.hide();

                        } else {
                            if (response.message != '') xSwal.error("Error", response.message);
                            xSplash.hide();

                        }

                        $('#ModalDetail').modal('toggle');
                    }
                });
            }



            onClickDescription = function (row = null) {
                console.log(row);

                $.each(row, function (key, value) {
                    $('#frmModalDescription #' + key).val(value);
                });

                $('#ModalDescription').modal('toggle');
                
            }

        });


    </script>
}
