<!-- Modal Data -->
<div class="modal fade" id="ModalData" tabindex="-1" aria-labelledby="ModalDataLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form id="frmModalData">
                <div class="modal-header">
                    <h5 class="modal-title" id="frmModalDataLabel">History Logs<span></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="padding:20px;">
                    <input type="hidden" class="form-control" id="_ID" name="_ID">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <div class="form-floating mb-2">
                                <input type="text" class="form-control" id="Code" name="Code" readonly>
                                <label for="Code">Code<span style="color:red">*</span></label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating mb-2">
                                <input type="text" class="form-control" id="ActionAt" name="ActionAt" readonly>
                                <label for="ActionAt">Date<span style="color:red">*</span></label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md">
                            <div class="form-floating mb-2">
                                <input type="text" class="form-control" id="Name" name="Name" readonly>
                                <label for="Name">Name<span style="color:red">*</span></label>
                            </div>
                        </div>
                        <div class="col-md">
                            <div class="form-floating mb-2">
                                <input type="text" class="form-control" id="Surname" name="Surname" readonly>
                                <label for="Surname">Surname<span style="color:red">*</span></label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md">
                            <div class="form-floating mb-2">
                                <input type="text" class="form-control" id="NameTH" name="NameTH" readonly>
                                <label for="NameTH">ชื่อ</label>
                            </div>
                        </div>
                        <div class="col-md">
                            <div class="form-floating mb-2">
                                <input type="text" class="form-control" id="SurnameTH" name="SurnameTH" readonly>
                                <label for="SurnameTH">นามสกุล</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md">
                            <div class="form-floating mb-2">
                                <table id="tblDetail" class="display" style="width:100%"></table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-reference">
                    <i class="modal-reference mr-auto" style="padding-left:20px;">Reference Code : <i id="_REFERCODE_">xxxxxxxx</i></i>
                    @if (ViewData["UserGroupID"].ToString() == "1")
                    {
                        <a href="#" data-bs-toggle="modal" data-bs-target="#ModalHistory" data-bs-remote="UserMaintenance">
                            <i class="fas fa-scroll" style="padding-right: 20px;" title="View History Log"></i>
                        </a>
                    }
                </div>
                <div class="modal-footer" style="padding-left:25px; padding-right:25px;">
                    <button type="button" class="btn btn-secondary" id="btnCancel" data-bs-dismiss="modal">@Html.i18nItem(language:ViewData["UserLanguage"].ToString(),item:"UserMaintenance.modal.user_detail.close")</button>
                </div>
            </form>
        </div>
    </div>
</div>


