                            </div>
                            <div class="col">
                                <button type="button" class="btn btn-danger col" id="buttonExit">
                                    <i class="fa-solid fa-door-open"></i>
                                    Exit
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="divRead">
                    <div class="row text-center mt-2">
                        <div class="col-10">
                            <div class="row">
                                <div class="col">
