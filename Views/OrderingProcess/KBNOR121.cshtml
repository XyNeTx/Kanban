                                <div class="col input-group">
                                    <label class="input-group-text" for="readLimitTrip">Total Limit/Trip</label>
                                    <input type="text" class="form-control text-center" id="readLimitTrip" readonly />
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="row">
                                <div class="input-group" >
                                    <label class="input-group-text col-7" for="readStdBPcs">Std+B(Pcs.) </label>
                                    <input type="text" class="form-control text-center" id="readStdBPcs" readonly />
                                </div>
                            </div>
                            <div class="row">
                                <div class="input-group">
                                    <label class="input-group-text col-7" for="readStdStock">Std.Stock(Pcs.) </label>
                                    <input type="text" class="form-control text-center" id="readStdStock" readonly />
