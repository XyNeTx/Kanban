                            </div>
                            <div class="row">
                                <div class="input-group">
                                    <label class="input-group-text col-7" for="readMinStock">Min.Stock(Pcs.) </label>
                                    <input type="text" class="form-control text-center" id="readMinStock" readonly />
                                </div>
                            </div>
                        </div>
                    </div>
