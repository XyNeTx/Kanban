                                    <i class="fa-solid fa-link"></i>
                                    Process
                                </button>
                                <button type="button" class="btn btn-primary col-3" id="btnPreview">
                                    <i class="fa-solid fa-binoculars"></i>
                                    Preview
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-5 p-4" style="border:solid;border-color:aqua;border-width:medium;border-left:0px">
