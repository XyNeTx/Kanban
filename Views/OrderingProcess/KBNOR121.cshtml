                                <input type="checkbox" class="form-check-input" id="chkBoxOrderTable" />
                                <label class="form-check-label text-primary" for="chkBoxOrderTable">Order Table</label>
                            </div>
                            <div class="col">
                                <input type="checkbox" class="form-check-input" id="chkBoxSliceTable" />
                                <label class="form-check-label text-primary" for="chkBoxSliceTable">Slice Order</label>
                            </div>
                        </div>
                        <div class="row ms-2">
                            <div class="col-7"> 
