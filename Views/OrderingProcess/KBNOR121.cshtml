                            <div class="input-group">
                                <label class="input-group-text" for="inputProcessShiftFor">Process Shift For :</label>
                                <input type="text" class="form-control" id="inputProcessShiftFor" value="" readonly>
                            </div>
                            <div class="input-group">
                                <label class="input-group-text" for="inputPlant">Plant :</label>
                                <input type="text" class="form-control" id="inputPlant" readonly>
                            </div>
                            <div class="input-group">
                                <label class="input-group-text" for="inputOrderType">Order Type :</label>
                                <input type="text" class="form-control" id="inputOrderType" value="Daily Order" readonly>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col">
                                <button type="button" class="btn btn-primary col" id="buttonReport">
                                    <i class="fas fa-file-text" aria-hidden="true"></i>
                                    Report
