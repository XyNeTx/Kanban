                                <select class="form-select" id="inputSupplier">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="input-group col-7">
                                <label class="input-group-text col-5" for="inputKanban">Kanban :</label>
                                <select class="form-select" id="inputKanban">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                            <div class="input-group col-5">
                                <label class="input-group-text" for="inputKanbanTo">To :</label>
                                <select class="form-select" id="inputKanbanTo">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="input-group col-7">
                                <label class="input-group-text col-5" for="inputStore">Store Code :</label>
                                <select class="form-select" id="inputStore">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                            <div class="input-group col-5">
                                <label class="input-group-text" for="inputStoreTo">To :</label>
                                <select class="form-select" id="inputStoreTo">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="input-group col-7">
                                <label class="input-group-text col-5" for="inputPart">Part No. :</label>
                                <select class="form-select" id="inputPart">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                            <div class="input-group col-5">
                                <label class="input-group-text" for="inputPartTo">To :</label>
                                <select class="form-select" id="inputPartTo">
                                    <option value="" hidden></option>
                                </select>
                            </div>
                        </div>
