                            </div>
                            <div class="col">
                                <input type="radio" class="form-check-input" id="radioKbAdd"/>
                                <label class="form-check-label text-primary" for="radioKbAdd">Add</label>
                            </div>
                            <div class="col">
                                <input type="radio" class="form-check-input" id="radioKbCut"/>
                                <label class="form-check-label text-primary" for="radioKbCut">Cut</label>
                            </div>
                        </div>
                    </div>
                    <div class="col">
