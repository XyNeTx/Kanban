                            <div class="col">
                                <span class="d-flex justify-content-center text-center" style="font-size:6rem;font-weight:bolder;margin-bottom:auto;">Daily</span>
                                <span class="d-flex justify-content-center text-center fs-4 fw-bold">Normal Order</span>
                            </div>
                            <div class="col">
                                <div class="row">
                                    <div class="col mt-1">
                                        <span class="fs-6">กระดานแจ้งข่าว : </span>
                                    </div>
                                    <div class="col">
                                        <button type="button" class="btn btn-outline-dark float-end" id="btnEditNews">แก้ไขข่าว</button>
                                    </div>
                                </div>
                                <div class="row">
                                    <textarea class="form-control mt-2 fs-6" id="txtNews" rows="6"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-3 p-1 pt-4" style="border:solid;border-color:aqua;border-width:medium;border-left:0px">
