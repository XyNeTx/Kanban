<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <form id="frmCondition">

                    <div class="row">
                        <div class="col">

                            <fieldset class="fieldset">
                                <legend>Current Process Information :</legend>

                                <div class="row">
                                    <div class="col-6">

                                        <div class="row">
                                            <div class="col-6">
                                                <item type="text" id="txtProcessDate" label="Process Date :" value="@ViewData["_ProcessDate"]" readonly></item>
                                            </div>
                                            <div class="col-6">
                                                <item type="text" id="txtPlant" label="Plant :" value="@ViewData["_Plant"]" readonly></item>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-6">

                                        <div class="row">
                                            <div class="col-6">
                                                <item type="text" id="txtProcessShift" label="Process Shift :" value="@ViewData["_ShiftTitle"]?.ToString()" readonly></item>
                                            </div>
                                            <div class="col-6">
                                                <item type="text" id="txtOrderType" label="Order Type :" value="Normal Order" readonly></item>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                            </fieldset>

                            <fieldset class="fieldset">
                                <legend>Process For :</legend>

                                <div class="row">
                                    <div class="col-6">

                                        <div class="row">
                                            <div class="col-6">
                                                <item type="date" id="txtProcessForDate" label="Date :" format="yyyy-mm-dd" default="now"></item>
                                            </div>
                                            <div class="col-6">
                                                <item type="text" id="txtProcessForShift" label="Shift :" value="@ViewData["_ShiftTitle"]?.ToString()" readonly></item>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="col-6">
                                        <div class="row">
                                            <div class="col"></div>
                                            <div class="col">
                                                <item type="button" id="btnCalculate" label="Calculate" style="width:100%"></item>
                                            </div>
                                            <div class="col">
                                                <item type="button" id="btnReport" label="Report" style="width:100%"></item>
                                            </div>
                                            <div class="col">
                                                <item type="button" id="btnExit" label="Exit" style="width:100%"></item>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mt-3">
                                    <div class="col">
                                        <div id="divProgressBar" style="visibility:hidden">
                                            <div class="progress" role="progressbar">
                                                <div class="progress-bar progress-bar-striped progress-bar-animated" id="widthProgressBar" style="width: 0%">
                                                    <span class="text-center" id="spanProgressBar"> Calculating Data </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </fieldset>

                        </div>
                    </div>

                </form>

                <div class="row">
                    <div class="col mt-4">
                        <item type="label" id="lblProcessFor" label="PROCESS FOR :"></item>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>




@section Scripts{
    <script type="text/javascript" src="~/assets/.script/OrderingProcess/KBNOR120.js?@ViewData["Version"]"></script>
}
