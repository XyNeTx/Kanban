<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <form id="frmCondition">

                    <div class="row">
                        <div class="col">

                            <fieldset class="fieldset">
                                <legend>Current Process Information :</legend>

                                <div class="row">
                                    <div class="col">

                                        <div class="row">
                                            <div class="col-4">
                                                <item type="text" id="txtProcessDate" label="Process Date :" value="@ViewData["_ProcessDate"]" readonly></item>
                                            </div>
                                            <div class="col-4">
                                                <item type="text" id="txtPlant" label="Plant :" value="@ViewData["_Plant"]" readonly></item>
                                            </div>
                                            <div class="col-4">
                                                <item type="text" id="txtProcessShift" label="Process Shift :" value="@ViewData["_ShiftTitle"]?.ToString()" readonly></item>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                            </fieldset>


                            <fieldset class="fieldset">
                                <legend>Search Data :</legend>

                                <div class="row">
                                    <div class="col-8">

                                        <div class="row">
                                            <div class="col-6">
                                                <div class="input-group">
                                                    <label for="ddlPDSNo" class="input-group-text">PDS No :</label>
                                                    <select class="form-control" id="ddlPDSNo" data-live-search="true" name="ddlPDSNo" style="width:100%">
                                                        <option value="">-- Select PDS No --</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-3">
                                                <item type="button" id="btnSearch" label="Search" style="width:100%"></item>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-4">
                                                <item type="text" id="txtSupplierCode" label="Supplier Code :" readonly></item>
                                            </div>
                                            <div class="col">
                                                <item type="text" id="txtSupplierName" label="" readonly></item>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-4">
                                                <item type="text" id="txtDeliveryDate" label="Delivery Date :" readonly></item>
                                            </div>
                                            <div class="col-2">
                                                <item type="text" id="txtDeliveryTrip" label="Trip :" readonly></item>
                                            </div>
                                            <div class="col-3">
                                                <item type="text" id="txtStoreCode" label="Store Code :" readonly></item>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="col">
                                        <item type="textarea" id="txtStatus" label="Status :" readonly></item>
                                    </div>
                                </div>


                            </fieldset>

                        </div>
                    </div>

                </form>

                <div class="row">
                    <div class="col mt-4">
                        <item type="table" id="tblMaster" legend="Detail"></item>
                    </div>
                </div>

                <div class="row mt-5">
                    <div class="col">
                        <item type="progress" id="prgProcess" label="Process : {{##.##}} %" max="100"></item>
                    </div>
                </div>

                <div class="row">
                    <div class="col">
                    </div>
                    <div class="col-6">
                        <div class="row">
                            <div class="col">
                            </div>
                            <div class="col-3">
                                <item type="button" id="btnDelete" label="Delete PDS" style="width:100%"></item>
                            </div>
                            <div class="col-3">
                                <item type="button" id="btnExit" label="Exit" style="width:100%"></item>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>





@using KANBAN.Libs
@section Scripts {
    <script type="text/javascript" src="@FileVersionHelper.VersionedScriptPath("/assets/.script/OrderingProcess/KBNOR620.js")"></script>
}
