<div class="row">

    <!-- Left Panel -->
    <div class="col-xl-6 col-md-6 col-sm-6 mb-2">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">

                <div class="row g-2">

                    <div class="accordion" id="acdProcess">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#acdProcesscl1" aria-expanded="true" aria-controls="acdProcesscl1">
                                    Process of Normal Ordering
                                </button>
                            </h2>
                            <div id="acdProcesscl1" class="accordion-collapse collapse show" data-bs-parent="#acdProcess">
                                <div class="accordion-body">
                                    <div class="form-group row g-2">
                                        <div class="col">
                                            <a href="../OrderingProcess/KBNOR110">
                                                <button type="button" class="btn btn-primary" id="btnKBNOR110">
                                                    1. Interface Daba from Import Order
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                    <div class="form-group row g-2">
                                        <div class="col">
                                            <a href="../OrderingProcess/KBNOR120">
                                                <button type="button" class="btn btn-primary" id="btnKBNOR120">
                                                    2. Calculate Normal Order
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                    <div class="form-group row g-2">
                                        <div class="col-md-12">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <a href="../OrderingProcess/KBNOR121">
                                                        <button type="button" class="btn btn-primary" id="btnKBNOR121">
                                                            3.1 Daily order
                                                        </button>
                                                    </a>
                                                </div>
                                                <div class="col-md-4">
                                                    <a href="../OrderingProcess/KBNOR121">
                                                        <button type="button" class="btn btn-primary" id="btnKBNOR122">
                                                            3.2 Pattern order
                                                        </button>
                                                    </a>
                                                </div>
                                                <div class="col-md-4">
                                                    <a href="../OrderingProcess/KBNOR121">
                                                        <button type="button" class="btn btn-primary" id="btnKBNOR123">
                                                            3.3 Non-Daily order
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group row g-2">
                                        <div class="col">
                                            <button type="button" class="btn btn-primary" id="btnSave">
                                                4. Generate PDS for Normal Order Data
                                            </button>
                                        </div>
                                    </div>
                                    <div class="form-group row g-2">
                                        <div class="col">
                                            <button type="button" class="btn btn-primary" id="btnSave">
                                                5. Print PDS and Kanban Card for Normal
                                            </button>
                                        </div>
                                    </div>
                                    <div class="form-group row g-2">
                                        <div class="col">
                                            <button type="button" class="btn btn-primary" id="btnSave">
                                                6. Refistration Normal Order Data
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>


    <!-- Middle Panel -->
    <div class="col-xl-3 col-md-3 col-sm-3 mb-2">
        <div class="card shadow h-100 py-2">
            <div class="card-body">

                <div class="accordion" id="acdReport">

                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#acdReportcl1" aria-expanded="true" aria-controls="acdReportcl1">
                                Report :
                            </button>
                        </h2>
                        <div id="acdReportcl1" class="accordion-collapse collapse show" data-bs-parent="#acdReport">
                            <div class="accordion-body">
                                <div class="form-group row">
                                    <div class="col">
                                        <button type="button" class="btn btn-primary" id="btnSave">
                                            Checking MRP Data
                                        </button>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col">
                                        <button type="button" class="btn btn-primary" id="btnSave">
                                            Export Order Data
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>


    <!-- Right Panel -->
    <div class="col-xl-3 col-md-3 col-sm-3 mb-2">
        <div class="card shadow h-100 py-2">
            <div class="card-body">

                <div class="accordion" id="acdInformation">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#acdInformationcl1" aria-expanded="true" aria-controls="acdInformationcl1">
                                Current Process Information :
                            </button>
                        </h2>
                        <div id="acdInformationcl1" class="accordion-collapse collapse show" data-bs-parent="#acdInformation">
                            <div class="accordion-body">
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Date :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="15/08/2023" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Plant :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="3 : Fac-3" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Shift :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="1 : Day Shift" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Type :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="Normal Ordering" readonly>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#acdInformationcl2" aria-expanded="true" aria-controls="acdInformationcl2">
                                Process For :
                            </button>
                        </h2>
                        <div id="acdInformationcl2" class="accordion-collapse collapse show" data-bs-parent="#acdInformation">
                            <div class="accordion-body">
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Date :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="16/08/2023" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Shift :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="Day" readonly>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#acdInformationcl3" aria-expanded="true" aria-controls="acdInformationcl3">
                                Last Process :
                            </button>
                        </h2>
                        <div id="acdInformationcl3" class="accordion-collapse collapse show" data-bs-parent="#acdInformation">
                            <div class="accordion-body">
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Date :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="16/08/2023" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md">
                                        <div class="input-group">
                                            <label class="input-group-text" for="F_OrderType">Shift :</label>
                                            <input type="text" class="form-control" id="F_OrderType" name="F_OrderType" value="Night" readonly>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>



