<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">
                <form id="frmCondition">
                    <fieldset class="fieldset">
                        <legend>Search Condition</legend>
                        <div class="row mb-4">
                            <div class="col ms-2">
                                <div class="w-75">
                                    <label class="input-group-text" for="F_MonthFrom">
                                        Month From : &nbsp;
                                        <select id="F_MonthFrom" class="form-select" label="Supplier From : ">
                                            <option id="monthFromBlank"></option>
                                        </select>
                                    </label>
                                </div>
                            </div>
                            <div class="col">
                                <div class="w-50">
                                    <label class="input-group-text" for="F_MonthTo">
                                        To : &nbsp;
                                        <select id="F_MonthTo" class="form-select" label="Supplier To : ">
                                            <option id="monthToBlank"></option>
                                        </select>
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col ms-2">
                                <div class="w-75">
                                    <label class="input-group-text" for="F_StoreFrom">
                                        Store Code From : &nbsp;
                                        <select id="F_StoreFrom" class="form-select">
                                            <option id="StoreFromBlank"></option>
                                        </select>
                                    </label>
                                </div>
                            </div>
                            <div class="col">
                                <div class="w-50">
                                    <label class="input-group-text" for="F_StoreTo">
                                        To : &nbsp;
                                        <select id="F_StoreTo" class="form-select">
                                            <option id="StoreToBlank"></option>
                                        </select>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                </form>
                <div class="row mt-4">
                    <div class="col d-flex justify-content-end align-text-bottom align-items-end align-content-end">
                        <item type="button" style="height:fit-content" id="ReportBtn" label="Report"></item>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="~/assets/js/History/UserMaintenance.js"></script>
    <script type="text/javascript" src="~/assets/.script/Template/Master.js"></script>
    <script type="text/javascript" src="~/assets/.script/OrderReport/KBNRT140.js?@ViewData["Version"]"></script>
}