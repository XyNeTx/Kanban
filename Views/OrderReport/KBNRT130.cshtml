<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">
                <form id="frmCondition">
                    <fieldset class="fieldset">
                        <legend>Search Condition</legend>
                        <div class="row mb-4">
                            <div class="col-4 me-4">
                                <label class="input-group-text" for="F_MonthFrom">
                                    Production Month From : &nbsp;
                                    <select id="F_MonthFrom" class="form-select" label="Supplier From : ">
                                        <option id="monthFromBlank"></option>
                                    </select>
                                </label>
                            </div>
                            <div class="col-3 ms-4">
                                <label class="input-group-text" for="F_MonthTo">
                                    To : &nbsp;
                                    <select id="F_MonthTo" class="form-select" label="Supplier To : ">
                                        <option id="monthToBlank"></option>
                                    </select>
                                </label>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-4 me-4">
                                <label class="input-group-text" for="F_SubFrom">
                                    Supplier Code From : &nbsp;
                                    <select id="F_SupFrom" class="form-select" label="Supplier From : ">
                                        <option id="supFromBlank"></option>
                                    </select>
                                </label>
                            </div>
                            <div class="col-3 ms-4">
                                <label class="input-group-text" for="F_SubTo">
                                    To : &nbsp;
                                    <select id="F_SupTo" class="form-select" label="To : ">
                                        <option id="supToBlank"></option>
                                    </select>
                                </label>
                            </div>
                        </div>
                    </fieldset>
                </form>
                <div class="row mt-4">
                    <div class="col d-flex justify-content-end align-text-bottom align-items-end align-content-end">
                        <item type="button" style="height:fit-content" id="ReportBtn" label="Report"></item>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    
    @*<script type="text/javascript" src="~/assets/.script/Template/Master.js"></script>*@
    <script type="text/javascript" src="~/assets/.script/OrderReport/KBNRT130.js?@ViewData["Version"]"></script>
}