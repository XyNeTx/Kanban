@{
    string now = DateTime.Now.ToString("yyyy-MM-dd");
}
<head>
    <style>
        .table-bordered th, .table-bordered td{
            border: 2px solid  #000000;
        }
    </style>
</head>
<div class="row">

    <div class="col-xl-12 col-md-12 col-sm-12">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">

                <form id="frmCondition">

                    <fieldset class="fieldset">
                        <legend>Management : </legend>

                        <div class="row">
                            <div class="col-3">
                                <item type="select" id="F_Customer" label="Customer"></item>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3">
                                <div class="input-group">
                                    <label class="input-group-text">Process Date</label>
                                    <input type="date" id="F_Process_Date" class="form-control" value="@now" />
                                </div>
                            </div>
                        </div>

                        <table id="tableManage" class="table table-bordered mt-3">
                            <thead class="text-center">
                                <tr>
                                    <th class="fs-4 col-2" scope="col">LINE</t>
                                    <th class="fs-4 col-2" scope="col">FRAME</th>
                                    <th class="fs-4 col-2" scope="col">DEDION</th>
                                    <th class="fs-4 col-2" scope="col">TAIL GATE</th>
                                    <th class="fs-4 col-2" scope="col">RR AXLE</th>
                                </tr>
                            </thead>
                            <tbody class="text-center">
                                <tr>
                                    <th class="fs-5" scope="row">Start Jig-In Seq.</th>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                </tr>
                                <tr>
                                    <th class="fs-5" scope="row">Remain Unit</th>
                                    <td class="fs-5"><input type="number" class="w-100 border-0 text-center" /></td>
                                    <td class="fs-5"><input type="number" class="w-100 border-0 text-center" /></td>
                                    <td class="fs-5"><input type="number" class="w-100 border-0 text-center" /></td>
                                    <td class="fs-5"><input type="number" class="w-100 border-0 text-center" /></td>
                                </tr>
                                <tr>
                                    <th class="fs-5" scope="row">End Jig-In Seq.</th>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                </tr>
                            </tbody>
                        </table>

                    </fieldset>
                    

                    <fieldset class="fieldset mt-3">
                        <legend>Confirmation for CKD - Inhouse Ordering : </legend>

                        <table id="tableCKD" class="table table-bordered ">
                            <thead class="text-center">
                                <tr>
                                    <th class="fs-4 col-2" scope="col" hidden>LINE</t>
                                    <th class="fs-4 col-2" scope="col" hidden>FRAME</th>
                                    <th class="fs-4 col-2" scope="col" hidden>DEDION</th>
                                    <th class="fs-4 col-2" scope="col" hidden>TAIL GATE</th>
                                    <th class="fs-4 col-2" scope="col" hidden>RR AXLE</th>
                                </tr>
                            </thead>
                            <tbody class="text-center">
                                <tr>
                                    <th class="fs-5 col-2" scope="row">Start Jig-In Seq.</th>
                                    <td class="fs-5 col-2"></td>
                                    <td class="fs-5 col-2"></td>
                                    <td class="fs-5 col-2"></td>
                                    <td class="fs-5 col-2"></td>
                                </tr>
                                <tr>
                                    <th class="fs-5" scope="row">End Jig-In Seq.</th>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                    <td class="fs-5"></td>
                                </tr>
                            </tbody>
                        </table>

                    </fieldset>
                </form>
                <button type="button" class="btn btn-primary float-end mt-3" id="buttonConfirm">confirm</button>

            </div>
        </div>
    </div>

</div>



@section Scripts{
    
    @*<script type="text/javascript" src="~/assets/.script/Template/Master.js"></script>*@
    <script type="text/javascript" src="~/assets/.script/VLTData/KBNIM0042.js?@ViewData["Version"]"></script>
}
