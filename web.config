<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<location path="." inheritInChildApplications="false">
		<system.webServer>
			<handlers>
				<add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
			</handlers>
			<aspNetCore processPath="dotnet" arguments=".\Kanban.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
		</system.webServer>
	</location>
	<system.web>
		<authentication mode="None" />
	</system.web>
	<location path="AD">
		<system.web>
      <authorization>
        <allow users="*" />
      </authorization>
		</system.web>
	</location>
	<system.webServer>
		<httpErrors>
			<remove statusCode="404" subStatusCode="-1" />
			<error statusCode="404" prefixLanguageFilePath="" path="http://hmmta-tpcap/kanban/Login" responseMode="Redirect" />
		</httpErrors>
	</system.webServer>
</configuration>
